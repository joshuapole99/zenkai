{
  "name": "zenkai-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web":     "npm run dev     --workspace=apps/web",
    "dev:scanner": "npm run dev     --workspace=apps/scanner",
    "build:web":   "npm run build   --workspace=apps/web",
    "build:scanner":"npm run build  --workspace=apps/scanner",
    "build":       "npm run build --workspaces --if-present"
  }
}
